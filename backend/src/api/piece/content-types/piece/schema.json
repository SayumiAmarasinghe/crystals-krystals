{
  "kind": "collectionType",
  "collectionName": "pieces",
  "info": {
    "singularName": "piece",
    "pluralName": "pieces",
    "displayName": "Piece"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "Description": {
      "type": "blocks",
      "required": true
    },
    "Notes": {
      "type": "blocks"
    },
    "Collection": {
      "type": "string"
    },
    "Photo": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "pieces"
    }
  }
}