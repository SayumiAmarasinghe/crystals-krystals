{
  "kind": "collectionType",
  "collectionName": "pieces",
  "info": {
    "singularName": "piece",
    "pluralName": "pieces",
    "displayName": "Piece"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "Price": {
      "type": "decimal",
      "required": true
    },
    "Description": {
      "type": "blocks",
      "required": true
    },
    "Notes": {
      "type": "blocks"
    },
    "Photo": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Material": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Polymer Clay",
        "Beaded",
        "Gold Filled",
        "Gold",
        "Silver"
      ]
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "mappedBy": "pieces"
    }
  }
}
